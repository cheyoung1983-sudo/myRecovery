{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and recovery status",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "sobrietyDate": { "type": "string", "format": "date" },
        "neighborhood": { "type": "string" },
        "recoveryNeeds": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "role": { "type": "string", "enum": ["user", "mentor", "admin"] },
        "fcmToken": { "type": "string" },
        "notificationsEnabled": { "type": "boolean" },
        "alias": { "type": "string" },
        "isCrisisAvailable": { "type": "boolean" },
        "emergencyMentorId": { "type": "string" },
        "points": { "type": "number", "default": 0 },
        "badges": { 
          "type": "array", 
          "items": { "type": "string" } 
        }
      },
      "required": ["email", "name", "role"]
    },
    "SpokaneResource": {
      "title": "Spokane Community Resource",
      "description": "Local help organizations and services",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["health", "food", "shelter", "crisis", "legal"] },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "website": { "type": "string" },
        "description": { "type": "string" },
        "tags": { 
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["name", "category", "description"]
    },
    "MeetingBuddy": {
      "title": "Meeting Buddy queue entry",
      "description": "User waiting at a meeting door for a buddy",
      "type": "object",
      "properties": {
        "meetingId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAlias": { "type": "string" },
        "arrivalTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["waiting", "matched", "completed"] }
      },
      "required": ["meetingId", "userId", "userName", "arrivalTime", "status"]
    },
    "NeighborhoodAnnouncement": {
      "title": "Neighborhood-specific announcement",
      "description": "Read-only channel announcements for local sober events",
      "type": "object",
      "properties": {
        "neighborhood": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["event", "update", "alert"] },
        "authorId": { "type": "string" }
      },
      "required": ["neighborhood", "content", "createdAt", "type", "authorId"]
    },
    "NeighborhoodPost": {
      "title": "Community Post",
      "description": "User post in the neighborhood feed for support or questions",
      "type": "object",
      "properties": {
        "neighborhood": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "supportCount": { "type": "number", "default": 0 },
        "isNewcomer": { "type": "boolean" }
      },
      "required": ["neighborhood", "userId", "userName", "content", "createdAt"]
    },
    "AIReflection": {
      "title": "AI-generated recovery reflection",
      "description": "Personalized reflection based on mood history",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "reflection": { "type": "string" },
        "generatedAt": { "type": "string", "format": "date-time" },
        "moodDataSummary": { "type": "string" }
      },
      "required": ["userId", "reflection", "generatedAt"]
    },
    "Meeting": {
      "title": "Recovery Meeting",
      "description": "Details of AA/NA meetings in Spokane",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "neighborhood": { "type": "string" },
        "address": { "type": "string" },
        "time": { "type": "string" },
        "day": { "type": "string" },
        "fellowship": { "type": "string", "enum": ["AA", "NA"] },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "format": { "type": "string" },
        "sponsors": { 
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["name", "neighborhood", "address", "time", "day", "fellowship", "lat", "lng"]
    },
    "Sponsor": {
      "title": "Recovery Mentor",
      "description": "Verified recovery mentors/sponsors",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "years": { "type": "number" },
        "bio": { "type": "string" },
        "specialties": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "isVerified": { "type": "boolean" },
        "verifiedAt": { "type": "string", "format": "date-time" },
        "verifiedBy": { "type": "string" },
        "neighborhood": { "type": "string" }
      },
      "required": ["userId", "name", "years", "status", "isVerified"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "Communication between user and mentor",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mentorUserId": { "type": "string" },
        "sponsorId": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mentorUserId", "sponsorId", "lastMessageAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "Individual message in a chat",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "text", "timestamp"]
    },
    "Attendance": {
      "title": "Attendance Record",
      "description": "User attendance at a meeting",
      "type": "object",
      "properties": {
        "meetingId": { "type": "string" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["meetingId", "date"]
    },
    "Review": {
      "title": "Meeting Review",
      "description": "User rating and comment for a meeting",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "rating", "comment", "timestamp"]
    },
    "MentorReview": {
      "title": "Mentor Review",
      "description": "User feedback for a recovery mentor",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "rating", "comment", "timestamp"]
    },
    "MoodEntry": {
      "title": "Mood Log",
      "description": "Daily wellness check-in",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mood": { "type": "string", "enum": ["great", "good", "okay", "struggling", "crisis"] },
        "note": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mood", "timestamp"]
    },
    "SmartABCLog": {
      "title": "SMART ABC Problem Solving Log",
      "description": "ABC worksheet database entries",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "activatingEvent": { "type": "string" },
        "beliefs": { "type": "string" },
        "consequences": { "type": "string" },
        "disputes": { "type": "string" },
        "effectiveBeliefs": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "activatingEvent", "beliefs", "consequences", "disputes", "effectiveBeliefs", "createdAt"]
    },
    "SmartCBALog": {
      "title": "SMART Cost-Benefit Analysis Log",
      "description": "CBA worksheet database entries",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "prosUsing": { "type": "string" },
        "consUsing": { "type": "string" },
        "prosSobriety": { "type": "string" },
        "consSobriety": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "prosUsing", "consUsing", "prosSobriety", "consSobriety", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "User meeting attendance records"
    },
    "/users/{userId}/moodLogs/{logId}": {
      "schema": "MoodEntry",
      "description": "User daily mood logs"
    },
    "/meetings/{meetingId}": {
      "schema": "Meeting",
      "description": "Directory of meetings"
    },
    "/meetings/{meetingId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "User reviews for a meeting"
    },
    "/sponsors/{sponsorId}": {
      "schema": "Sponsor",
      "description": "Available mentors"
    },
    "/sponsors/{sponsorId}/reviews/{reviewId}": {
      "schema": "MentorReview",
      "description": "User reviews for a mentor"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Active conversations"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Message history for a chat"
    },
    "/meetingBuddies/{buddyId}": {
      "schema": "MeetingBuddy",
      "description": "Users seeking buddies at meeting locations"
    },
    "/neighborhoodAnnouncements/{annId}": {
      "schema": "NeighborhoodAnnouncement",
      "description": "Local community updates"
    },
    "/neighborhoodPosts/{postId}": {
      "schema": "NeighborhoodPost",
      "description": "User-generated community posts"
    },
    "/neighborhoodPosts/{postId}/supports/{supportId}": {
      "schema": "User",
      "description": "Track who supported a post to award points"
    },
    "/users/{userId}/aiReflections/{reflId}": {
      "schema": "AIReflection",
      "description": "AI-generated wellness reflections"
    },
    "/spokaneResources/{resourceId}": {
      "schema": "SpokaneResource",
      "description": "Directory of local Spokane resources"
    },
    "/users/{userId}/abcLogs/{logId}": {
      "schema": "SmartABCLog",
      "description": "SMART Recovery ABC problem solving logs"
    },
    "/users/{userId}/cbaLogs/{logId}": {
      "schema": "SmartCBALog",
      "description": "SMART Recovery Cost-Benefit Analysis logs"
    }
  }
}
