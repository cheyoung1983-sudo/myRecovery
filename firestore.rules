rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true || true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isVerifiedUser() { return isSignedIn() && isEmailVerified(); }
    
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'cheyoung1983@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'role']) &&
             data.keys().size() <= 15 &&
             data.email is string && data.email.size() <= 256 &&
             data.name is string && data.name.size() <= 128 &&
             data.role in ['user', 'mentor', 'admin'] &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('sobrietyDate' in data) || (data.sobrietyDate is string && data.sobrietyDate.size() <= 50)) &&
             (!('neighborhood' in data) || (data.neighborhood is string && data.neighborhood.size() <= 100)) &&
             (!('recoveryNeeds' in data) || (data.recoveryNeeds is list && data.recoveryNeeds.size() <= 20)) &&
             (!('fcmToken' in data) || (data.fcmToken is string && data.fcmToken.size() <= 512)) &&
             (!('notificationsEnabled' in data) || (data.notificationsEnabled is bool)) &&
             (!('alias' in data) || (data.alias is string && data.alias.size() <= 100)) &&
             (!('isCrisisAvailable' in data) || (data.isCrisisAvailable is bool)) &&
             (!('emergencyMentorId' in data) || (data.emergencyMentorId is string && data.emergencyMentorId.size() <= 100)) &&
             (!('points' in data) || (data.points is number)) &&
             (!('badges' in data) || (data.badges is list && data.badges.size() <= 50));
    }

    function isValidSpokaneResource(data) {
      return data.keys().hasAll(['name', 'category', 'description']) &&
             data.name is string && data.name.size() <= 200 &&
             data.category in ['health', 'food', 'shelter', 'crisis', 'legal'] &&
             data.description is string && data.description.size() <= 2000 &&
             (!('address' in data) || (data.address is string)) &&
             (!('phone' in data) || (data.phone is string)) &&
             (!('website' in data) || (data.website is string)) &&
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 10));
    }

    function isValidMeetingBuddy(data) {
      return data.keys().hasAll(['meetingId', 'userId', 'userName', 'arrivalTime', 'status']) &&
             data.meetingId is string && data.userId == request.auth.uid &&
             data.userName is string &&
             data.arrivalTime == request.time &&
             data.status in ['waiting', 'matched', 'completed'] &&
             (!('userAlias' in data) || (data.userAlias is string));
    }

    function isValidAnnouncement(data) {
      return data.keys().hasAll(['neighborhood', 'content', 'createdAt', 'type', 'authorId']) &&
             data.neighborhood is string &&
             data.content is string && data.content.size() <= 5000 &&
             data.createdAt == request.time &&
             data.type in ['event', 'update', 'alert'] &&
             data.authorId == request.auth.uid;
    }

    function isValidAIReflection(data) {
      return data.keys().hasAll(['userId', 'reflection', 'generatedAt']) &&
             data.userId is string &&
             data.reflection is string &&
             data.generatedAt == request.time &&
             (!('moodDataSummary' in data) || (data.moodDataSummary is string));
    }

    function isValidNeighborhoodPost(data) {
      return data.keys().hasAll(['neighborhood', 'userId', 'userName', 'content', 'createdAt']) &&
             data.neighborhood is string &&
             data.userId == request.auth.uid &&
             data.userName is string &&
             data.content is string && data.content.size() <= 2000 &&
             data.createdAt == request.time &&
             (!('supportCount' in data) || (data.supportCount is number)) &&
             (!('isNewcomer' in data) || (data.isNewcomer is bool));
    }

     function isValidMeeting(data) {
      return data.keys().hasAll(['name', 'neighborhood', 'address', 'time', 'day', 'fellowship', 'lat', 'lng']) &&
             data.name is string && data.name.size() <= 200 &&
             data.neighborhood is string && data.neighborhood.size() <= 100 &&
             data.address is string && data.address.size() <= 500 &&
             data.time is string && data.time.size() <= 50 &&
             data.day is string && data.day.size() <= 20 &&
             data.fellowship in ['AA', 'NA'] &&
             data.lat is number && data.lng is number &&
             (!('format' in data) || (data.format is string && data.format.size() <= 100)) &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('isOpen' in data) || (data.isOpen is bool)) &&
             (!('sponsors' in data) || (data.sponsors is list && data.sponsors.size() <= 50));
    }

    function isValidSponsor(data) {
      return data.keys().hasAll(['userId', 'name', 'years', 'status', 'isVerified']) &&
             (data.userId == request.auth.uid || isAdmin()) &&
             data.name is string && data.name.size() <= 128 &&
             data.years is number && data.years >= 0 &&
             data.status in ['pending', 'verified', 'rejected'] &&
             data.isVerified is bool &&
             (!('verifiedAt' in data) || (data.verifiedAt is timestamp)) &&
             (!('verifiedBy' in data) || (data.verifiedBy is string)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 5000)) &&
             (!('neighborhood' in data) || (data.neighborhood is string && data.neighborhood.size() <= 100)) &&
             (!('specialties' in data) || (data.specialties is list && data.specialties.size() <= 15));
    }

    function isValidChat(data) {
      return data.keys().hasAll(['userId', 'mentorUserId', 'sponsorId', 'lastMessageAt']) &&
             data.userId is string && data.mentorUserId is string && data.sponsorId is string &&
             (data.lastMessageAt == request.time || data.lastMessageAt is timestamp);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'text', 'timestamp']) &&
             data.keys().size() <= 4 &&
             data.senderId == request.auth.uid &&
             data.text is string && data.text.size() <= 10000 &&
             data.timestamp == request.time &&
             (!('isCrisis' in data) || (data.isCrisis is bool));
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['meetingId', 'date']) &&
             data.meetingId is string && data.date is string;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['userId', 'userName', 'rating', 'comment', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() <= 128 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 2000 &&
             data.timestamp == request.time;
    }

    function isValidMoodLog(data) {
      return data.keys().hasAll(['userId', 'mood', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.mood in ['great', 'good', 'okay', 'struggling', 'crisis'] &&
             (!('note' in data) || (data.note is string && data.note.size() <= 2000)) &&
             data.timestamp == request.time;
    }

    // --- Collections ---

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().role == 'user' || 
        (incoming().role == 'admin' && request.auth.token.email == 'cheyoung1983@gmail.com')
      );
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        // Admin Case: Can change roles
        (isAdmin() && (
          // Protect the super admin from being demoted by others
          (existing().email != 'cheyoung1983@gmail.com' || request.auth.token.email == 'cheyoung1983@gmail.com') &&
          incoming().email == existing().email &&
          incoming().diff(existing()).affectedKeys().hasOnly(['role', 'name', 'photoURL', 'sobrietyDate', 'recoveryNeeds', 'neighborhood', 'fcmToken', 'notificationsEnabled', 'alias', 'isCrisisAvailable', 'emergencyMentorId', 'points', 'badges'])
        )) ||
        // Owner Case: Regular updates (cannot change role or email or points directly)
        (isOwner(userId) && 
          incoming().role == existing().role &&
          incoming().email == existing().email &&
          (!('points' in incoming()) || (incoming().points == existing().points)) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL', 'sobrietyDate', 'recoveryNeeds', 'neighborhood', 'fcmToken', 'notificationsEnabled', 'alias', 'isCrisisAvailable', 'emergencyMentorId', 'points', 'badges'])
        )
      );

      match /attendance/{attendanceId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidAttendance(incoming());
      }

      match /aiReflections/{reflId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isAdmin(); // Only generated via server/admin
      }

      match /moodLogs/{logId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidMoodLog(incoming());
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    match /meetings/{meetingId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isVerifiedUser() && isValidReview(incoming());
        allow update, delete: if isAdmin() || isOwner(existing().userId);
      }
    }

    match /sponsors/{sponsorId} {
      allow read: if true; // Allow all to view verified mentors, and we query appropriately
      allow create: if isVerifiedUser() && isValidSponsor(incoming()) && 
                    incoming().status == 'pending' && incoming().isVerified == false;
      allow update: if (isOwner(existing().userId) || isAdmin()) && isValidSponsor(incoming()) && (
        isAdmin() || (
          // Mentors can only edit bio/specialties/neighborhood if already verified
          existing().status == 'verified' &&
          incoming().status == existing().status &&
          incoming().isVerified == existing().isVerified &&
          incoming().userId == existing().userId &&
          incoming().diff(existing()).affectedKeys().hasOnly(['bio', 'specialties', 'neighborhood', 'name'])
        )
      );
      allow delete: if isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isVerifiedUser() && isValidReview(incoming());
        allow update, delete: if isAdmin() || isOwner(existing().userId);
      }
    }

    match /chats/{chatId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.mentorUserId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.mentorUserId == request.auth.uid || isAdmin());
      
      allow create: if isVerifiedUser() && isValidChat(incoming()) && (
        incoming().userId == request.auth.uid || 
        incoming().mentorUserId == request.auth.uid
      );
      
      allow update: if (resource.data.userId == request.auth.uid || resource.data.mentorUserId == request.auth.uid || isAdmin()) && 
                    isValidChat(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasAny(['lastMessageAt', 'typingStatus', 'lastRead']);

      match /messages/{messageId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid || get(/databases/$(database)/documents/chats/$(chatId)).data.mentorUserId == request.auth.uid || isAdmin());
        allow create: if isSignedIn() && (get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid || get(/databases/$(database)/documents/chats/$(chatId)).data.mentorUserId == request.auth.uid || isAdmin()) && isValidMessage(incoming());
      }
    }

    match /meetingBuddies/{buddyId} {
      allow read: if true;
      allow create: if isVerifiedUser() && isValidMeetingBuddy(incoming());
      allow update: if isOwner(existing().userId) || isAdmin();
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /neighborhoodAnnouncements/{annId} {
      allow read: if true;
      allow create: if isAdmin(); // Only admins can create official announcements
      allow delete: if isAdmin();
    }

    match /neighborhoodPosts/{postId} {
      allow read: if true;
      allow create: if isVerifiedUser() && isValidNeighborhoodPost(incoming());
      allow update: if (isOwner(existing().userId) || isAdmin()) && isValidNeighborhoodPost(incoming()) ||
                    (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['supportCount']));
      allow delete: if isOwner(existing().userId) || isAdmin();

      match /supports/{supportId} {
        allow read: if true;
        allow create: if isVerifiedUser() && supportId == request.auth.uid;
      }
    }

    match /spokaneResources/{resourceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
